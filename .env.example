# Wallet service local env
# Local repo values are used first, then bidmart-infrastructure/.env if present

# Production VPS + Supabase (VPS has no IPv6 — must use Session Pooler):
# DATABASE_URL=postgresql://postgres.pctktjwzbmoiftvkersb:<password>@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bidmart_wallet_db
PORT=8083
GRPC_PORT=50051

# Midtrans Snap sandbox
MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/v1/transactions
MIDTRANS_SERVER_KEY=SB-Mid-server-your-sandbox-key
MIDTRANS_CLIENT_KEY=SB-Mid-client-your-sandbox-key
MIDTRANS_IRIS_API_KEY=
MIDTRANS_IRIS_MERCHANT_KEY=
FRONTEND_BASE_URL=http://localhost:5173
# Production: FRONTEND_BASE_URL=https://bidmart-frontend.vercel.app

# RabbitMQ (shared CloudAMQP in prod/staging — same URL as Heroku auth/order CLOUDAMQP_URL)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/%2f
BIDMART_EVENTS_EXCHANGE=bidmart.events

# Internal service token (must match Heroku auth's GATEWAY_INTERNAL_TOKEN in prod/staging)
GATEWAY_INTERNAL_TOKEN=bidmart-local-internal-token

# Auction service for back-channel listing lookups
AUCTION_SERVICE_BASE_URL=http://localhost:8082/api/v1/listings

# Swagger UI (docker-compose)
SWAGGER_UI_PORT=8088
